{
    "buildCommand": "npm run build",
    "framework": "nextjs",
    "regions": ["sin1"],
    "functions": {
        "app/api/**/*.ts": {
            "maxDuration": 10
        }
    },
    "headers": [{
            "source": "/_next/static/(.*)",
            "headers": [{
                "key": "Cache-Control",
                "value": "public, max-age=31536000, immutable"
            }]
        },
        {
            "source": "/(.*)",
            "headers": [{
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}